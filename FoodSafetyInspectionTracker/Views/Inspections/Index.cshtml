@model IEnumerable<FoodSafetyInspectionTracker.Models.Inspection>

@{
    ViewData["Title"] = "Inspections";
}

<h1>Inspections</h1>

@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <p>
        <a asp-action="Create">Create New</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>Premises</th>
            <th>@Html.DisplayNameFor(model => model.InspectionDate)</th>
            <th>@Html.DisplayNameFor(model => model.Score)</th>
            <th>@Html.DisplayNameFor(model => model.Outcome)</th>
            <th>@Html.DisplayNameFor(model => model.Notes)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Premises?.Name</td>
                <td>@item.InspectionDate.ToShortDateString()</td>
                <td>@item.Score</td>
                <td>@item.Outcome</td>
                <td>@item.Notes</td>
                <td>
                    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <text> | </text>
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a>

                        @if (User.IsInRole("Admin"))
                        {
                            <text> | </text>
                            <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                        }
                    }
                    else
                    {
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>