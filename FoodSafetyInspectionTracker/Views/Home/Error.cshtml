@{
    ViewData["Title"] = "Error";
}

<div class="text-center mt-5">
    <h1 class="text-danger">Something went wrong</h1>
    <p class="lead">An unexpected error occurred while processing your request.</p>
    <p>Please try again later or contact support if the issue continues.</p>

    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary mt-3">
        Return to Dashboard
    </a>
</div>