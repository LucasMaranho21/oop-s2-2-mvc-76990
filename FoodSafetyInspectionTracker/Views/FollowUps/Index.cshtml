@model IEnumerable<FoodSafetyInspectionTracker.Models.FollowUp>

@{
    ViewData["Title"] = "Follow-Ups";
}

<h1>Follow-Ups</h1>

@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <p>
        <a asp-action="Create">Create New</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>Inspection ID</th>
            <th>@Html.DisplayNameFor(model => model.DueDate)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>@Html.DisplayNameFor(model => model.ClosedDate)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.InspectionId</td>
                <td>@item.DueDate.ToShortDateString()</td>
                <td>@item.Status</td>
                <td>@(item.ClosedDate?.ToShortDateString() ?? "-")</td>
                <td>
                    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <text> | </text>
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a>

                        @if (User.IsInRole("Admin"))
                        {
                            <text> | </text>
                            <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                        }
                    }
                    else
                    {
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>